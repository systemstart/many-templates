{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "schedule": [
    "before 9am on monday"
  ],
  "packageRules": [
    {
      "matchManagers": [
        "gomod"
      ],
      "commitMessagePrefix": "fix(deps):"
    },
    {
      "matchManagers": [
        "github-actions"
      ],
      "commitMessagePrefix": "ci(deps):"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.github/workflows/.*\\.yml$/"
      ],
      "matchStrings": [
        "GSEMVER_VERSION:\\s*\"(?<currentValue>.*?)\""
      ],
      "depNameTemplate": "arnaud-deprez/gsemver",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.*)$"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "go.mod"
      ],
      "matchStrings": [
        "\\ngo (?<currentValue>[^\\s]+)\\n"
      ],
      "depNameTemplate": "go",
      "datasourceTemplate": "golang-version"
    }
  ]
}
